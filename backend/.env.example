# --- Groq (AI Health Assistant) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Firebase (Auth + Firestore) ---
# Paste the full contents of your Firebase service account JSON on one line,
# OR set FIREBASE_CREDENTIALS_PATH to point at a mounted json file instead.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=

# --- Google Play Billing (subscription verification) ---
# Service account JSON for a service account with "View financial data" access
# in Play Console (Setup > API access). Same "paste JSON" or "path" pattern.
GOOGLE_PLAY_CREDENTIALS_JSON=
GOOGLE_PLAY_CREDENTIALS_PATH=
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.medsos
# The subscription product ID(s) configured in Play Console, comma-separated
GOOGLE_PLAY_SUBSCRIPTION_IDS=medsos_premium_monthly,medsos_premium_yearly

# --- App config ---
ENVIRONMENT=development
ALLOWED_ORIGINS=*
# Simple per-user rate limit for AI chat calls
AI_CHAT_RATE_LIMIT_PER_MINUTE=10
